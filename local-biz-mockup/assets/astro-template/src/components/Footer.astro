---
const year = new Date().getFullYear();
/* CUSTOMIZE: Update all contact info, links, and credentials below */
---

<footer class="bg-dark text-white gold-accent-top">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div>
        <img src="/images/logo.png" alt="BUSINESS_NAME" class="h-16 w-auto mb-6" />
        <p class="text-gray-400 text-sm leading-relaxed mb-4">
          <!-- CUSTOMIZE: Business description -->
          Brief description of the business and what makes it unique.
        </p>
      </div>

      <div>
        <h3 class="text-brand-primary font-heading text-lg mb-6">Quick Links</h3>
        <ul class="space-y-3">
          <li><a href="/" class="text-gray-400 hover:text-brand-primary transition-colors text-sm">Home</a></li>
          <li><a href="/services" class="text-gray-400 hover:text-brand-primary transition-colors text-sm">Services</a></li>
          <li><a href="/contact" class="text-gray-400 hover:text-brand-primary transition-colors text-sm">Contact</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-brand-primary font-heading text-lg mb-6">Contact Us</h3>
        <ul class="space-y-4 text-sm">
          <!-- CUSTOMIZE: Phone, email, address -->
          <li class="text-gray-400">PHONE_NUMBER</li>
          <li><a href="mailto:EMAIL" class="text-gray-400 hover:text-brand-primary transition-colors">EMAIL</a></li>
          <li class="text-gray-400">ADDRESS</li>
        </ul>
        <div class="mt-6 pt-4 border-t border-white/10">
          <!-- CUSTOMIZE: License and credential info -->
          <p class="text-xs text-muted">LICENSE_INFO</p>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 text-center">
      <p class="text-xs text-muted">&copy; {year} BUSINESS_NAME. All rights reserved.</p>
    </div>
  </div>
</footer>
